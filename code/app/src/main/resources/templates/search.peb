<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flight Search - Go Fly</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">✈ Go Fly</div>
      <div>
        <a href="/home.html">Home</a>
        <a href="/booking.html">View Bookings</a>
        <a href="/login.html">Sign In</a>
        <a href="/management.html">Management</a>
      </div>
    </div>
  </nav>

  <main class="hero">
    <div class="search-wrapper">
      <h2>Find Your Next Destination</h2>

      <form id="searchForm" action="/flights" method="GET">
        <div class="trip-selector">
          <label>
            <input type="radio" name="path" value="roundtrip" id="rt-option" checked>
            Round Trip
          </label>
          <label>
            <input type="radio" name="path" value="oneway" id="ow-option">
            One Way
          </label>
        </div>

        <div class="input-row">
          <div>
            <label>From</label>
            <input type="text" name="from" list="from-airports" placeholder="Select airport" required>
            <datalist id="from-airports">
              {% for airport in airports %}
                <option value="{{ airport }}">
              {% endfor %}
            </datalist>
          </div>
          <div>
            <label>To</label>
            <input type="text" name="to" list="to-airports" placeholder="Select airport" required>
            <datalist id="to-airports">
              {% for airport in airports %}
                <option value="{{ airport }}">
              {% endfor %}
            </datalist>
          </div>
        </div>

        <div class="input-row">
          <div>
            <label>Departure</label>
            <input type="date" id="dep-date" name="depart" required>
          </div>
          <div id="return-box">
            <label>Return</label>
            <input type="date" id="ret-date" name="return">
          </div>
        </div>

        <div class="input-row">
          <div>
            <label>Passengers</label>
            <input type="number" name="qty" min="1" value="1">
          </div>
          <div>
            <label>Cabin Class</label>
            <select name="class">
              <option value="econ">Economy</option>
              <option value="bus">Business</option>
            </select>
          </div>
        </div>

        <div class="submit-area">
          <button type="submit" class="btn-find">Search Flights</button>
        </div>
      </form>
    </div>
  </main>

  <script>
    const roundTrip = document.getElementById("rt-option");
    const oneWay = document.getElementById("ow-option");
    const departDate = document.getElementById("dep-date");
    const returnDate = document.getElementById("ret-date");
    const returnBox = document.getElementById("return-box");
    const searchForm = document.getElementById("searchForm");

    function updateTripType() {
      if (oneWay.checked) {
        returnBox.style.display = "none";
        returnDate.value = "";
        returnDate.disabled = true;
      } else {
        returnBox.style.display = "block";
        returnDate.disabled = false;
        returnDate.min = departDate.value;
      }
    }

    departDate.addEventListener("change", function () {
      returnDate.min = departDate.value;

      if (returnDate.value !== "" && returnDate.value < departDate.value) {
        returnDate.value = "";
      }
    });

    roundTrip.addEventListener("change", updateTripType);
    oneWay.addEventListener("change", updateTripType);

    searchForm.addEventListener("submit", function (event) {
      if (roundTrip.checked) {
        if (returnDate.value === "") {
          alert("Please choose a return date.");
          event.preventDefault();
        } else if (returnDate.value < departDate.value) {
          alert("Return date cannot be before departure date.");
          event.preventDefault();
        }
      }
    });

    updateTripType();
  </script>

</body>
</html>