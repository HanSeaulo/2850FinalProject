<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Search Flights</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <div class="bg bg-a" id="bgA"></div>
  <div class="bg bg-b" id="bgB"></div>

  <header class="navbar">
    <div class="nav-container">
      <div class="logo">✈ Go Fly</div>
      <nav>
        <a href="/">Home</a>
        <a href="/booking.html">View Bookings</a>
        <a href="/login">Sign In</a>
        <a href="/management.html">Management</a>
      </nav>
    </div>
  </header>

  <main class="hero">
    <div class="hero-bg" id="heroBgA"></div>
    <div class="hero-bg" id="heroBgB"></div>

    <div class="hero-inner">
      <div class="search-wrapper">
        <h2>Find Your Next Destination</h2>

        <form action="/flights" method="get">
          <div class="trip-selector">
            <label>
              <input type="radio" name="tripType" value="roundtrip" checked />
              Round Trip
            </label>
            <label>
              <input type="radio" name="tripType" value="oneway" />
              One Way
            </label>
          </div>

          <div class="input-row">
            <div>
              <label for="from">From</label>
              <select id="from" name="from" required>
                {% for airport in airports %}
                  <option value="{{ airport }}">{{ airport }}</option>
                {% endfor %}
              </select>
            </div>

            <div>
              <label for="to">To</label>
              <select id="to" name="to" required>
                {% for airport in airports %}
                  <option value="{{ airport }}">{{ airport }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="input-row">
            <div>
              <label for="depart">Departure</label>
              <input type="date" id="depart" name="depart" required />
            </div>

            <div>
              <label for="return">Return</label>
              <input type="date" id="return" name="return" />
            </div>
          </div>

          <div class="input-row">
            <div>
              <label for="qty">Passengers</label>
              <input type="number" id="qty" name="qty" min="1" value="1" required />
            </div>

            <div>
              <label for="class">Cabin Class</label>
              <select id="class" name="class" required>
                <option value="econ">Economy</option>
                <option value="bus">Business</option>
              </select>
            </div>
          </div>

          <div class="submit-area">
            <button type="submit" class="btn-find">Search Flights</button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    const images = ["/bg/bg1.jpeg", "/bg/bg2.jpeg", "/bg/bg3.jpeg"];

    let index = 0;
    let showingA = true;

    const bgA = document.getElementById("heroBgA");
    const bgB = document.getElementById("heroBgB");

    bgA.style.backgroundImage = "url('" + images[0] + "')";
    bgA.classList.add("show");

    setInterval(() => {
      index = (index + 1) % images.length;
      const next = images[index];

      const showEl = showingA ? bgB : bgA;
      const hideEl = showingA ? bgA : bgB;

      showEl.style.backgroundImage = "url('" + next + "')";
      showEl.classList.add("show");
      hideEl.classList.remove("show");

      showingA = !showingA;
    }, 6000);
  </script>

</body>
</html>