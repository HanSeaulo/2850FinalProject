<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Search Flights</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="nav-container">
      <div class="logo">✈ Go Fly</div>
      <nav>
        <a href="/">Home</a>
        <a href="/booking.html">View Bookings</a>
        <a href="/login">Sign In</a>
        <a href="/management.html">Management</a>
      </nav>
    </div>
  </header>

  <main class="hero search-only">
    <div class="hero-inner">
      <div class="search-wrapper">
        <h2>Find Your Next Destination</h2>

        <form action="/flights" method="get">
          <div class="trip-selector">
            <label>
              <input type="radio" name="tripType" value="roundtrip" checked />
              Round Trip
            </label>
            <label>
              <input type="radio" name="tripType" value="oneway" />
              One Way
            </label>
          </div>

          <div class="input-row">
            <div>
              <label for="from">From</label>
              <select id="from" name="from" required>
                <option value="" disabled selected>Select departure airport</option>
                {% for airport in airports %}
                  <option value="{{ airport }}">{{ airport }}</option>
                {% endfor %}
              </select>
            </div>

            <div>
              <label for="to">To</label>
              <select id="to" name="to" required>
                <option value="" disabled selected>Select destination airport</option>
                {% for airport in airports %}
                  <option value="{{ airport }}">{{ airport }}</option>
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="input-row">
            <div>
              <label for="depart">Departure</label>
              <input type="date" id="depart" name="depart" required />
            </div>

            <div id="return-container">
              <label for="return">Return</label>
              <input type="date" id="return" name="return" required />
            </div>
          </div>

          <div class="input-row">
            <div>
              <label for="qty">Passengers</label>
              <input type="number" id="qty" name="qty" min="1" value="1" required />
            </div>

            <div>
              <label for="class">Cabin Class</label>
              <select id="class" name="class" required>
                <option value="econ">Economy</option>
                <option value="bus">Business</option>
              </select>
            </div>
          </div>

          <div class="submit-area">
            <button type="submit" class="btn-find">Search Flights</button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    // Get all the elements we need to talk to
    var returnContainer = document.getElementById('return-container');
    var returnInput = document.getElementById('return');
    var departInput = document.getElementById('depart');

    // This function hides or shows the return date
    function toggleReturnField() {
      // Check which radio button is currently clicked
      var tripType = document.querySelector('input[name="tripType"]:checked').value;

      if (tripType === 'oneway') {
        returnContainer.style.display = 'none';
        returnInput.value = ''; 
        returnInput.required = false;
      } else {
        returnContainer.style.display = 'block';
        returnInput.required = true;
      }
    }

    // When the departure date changes, update the minimum return date
    departInput.onchange = function() {
      if (departInput.value != "") {
        returnInput.min = departInput.value; 
        
        // Clear return date if it's now earlier than departure
        if (returnInput.value < departInput.value) {
          returnInput.value = "";
        }
      }
    };

    // Add listeners to the radio buttons
    // We use a selector to find the inputs by name
    var radios = document.getElementsByName('tripType');
    for (var i = 0; i < radios.length; i++) {
      radios[i].onclick = toggleReturnField;
    }

    // Run once at the start to make sure the page is correct
    toggleReturnField();
  </script>

</body>
</html>